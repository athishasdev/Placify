# Active Profile: local | prod
SPRING_PROFILES_ACTIVE=local

# Server Port
SERVER_PORT=8080

# Database Configuration (PostgreSQL / Neon)
DATABASE_URL=jdbc:postgresql://localhost:5432/placify
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT Secret (Base64 encoded string, min 256 bits)
JWT_SECRET=WjNkbGRYa2dabTl5SUdGc2JHVjRJR2x1SUdOb2FXNW5JR0Z1WkNCc2IyNW5aWElnYzJWamNtVjBJSE5sWTNWeVpTQjBhR2x6SUhObFkzSmxkQT09

# Upload Storage Directory (Absolute or relative path)
UPLOAD_PATH=uploads/resumes

# Frontend URL (Used for CORS and redirects)
FRONTEND_URL=http://localhost:5500

# Allowed CORS Origins (Comma-separated for production)
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500

# API Base URL (Frontend environment configuration)
API_BASE_URL=http://localhost:8080/api

